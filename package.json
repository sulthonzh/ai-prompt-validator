{
  "name": "ai-prompt-validator",
  "version": "1.0.0",
  "description": "AI prompt validation, optimization, and testing toolkit for developers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aiv": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "node --test test/test.mjs test/comparator.test.mjs",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepare": "npm run build",
    "test:standalone": "node --test test/test.mjs"
  },
  "keywords": [
    "ai",
    "prompt",
    "validation",
    "optimization",
    "testing",
    "llm",
    "openai",
    "claude",
    "gemini",
    "developer-tools"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.4.0",
    "chalk": "^4.1.2",
    "commander": "^15.0.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^10.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sulthonzh/ai-prompt-validator.git"
  },
  "homepage": "https://github.com/sulthonzh/ai-prompt-validator#readme",
  "bugs": {
    "url": "https://github.com/sulthonzh/ai-prompt-validator/issues"
  }
}
